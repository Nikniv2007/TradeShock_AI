# ─────────────────────────────────────────────────────────────
# TradeShock AI — Environment Variables
# Copy this file to `.env.local`. The app runs fully in Demo Mode
# with NO keys set — mock AI + deterministic demo data.
# ─────────────────────────────────────────────────────────────

# AI providers (optional). If neither is set, mock AI is used.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model overrides (optional)
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_MODEL=gpt-4o-mini

# Supabase (optional — app uses local/in-memory store if unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App config
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_NAME=TradeShock AI
